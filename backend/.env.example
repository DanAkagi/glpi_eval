# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=back-office-secret-change-this-in-production
FRONTEND_URL=http://localhost:5173

# GLPI API
GLPI_API_URL=http://localhost/glpi/public/api.php
GLPI_CLIENT_ID=strId
GLPI_CLIENT_SECRET=clientSecretCode
# App-Token of a Legacy API client (Configuration > General > API > API Clients)
# Required for apirest.php (Item_Ticket, Document_Item linking). Different from GLPI_CLIENT_ID (OAuth2).
GLPI_APP_TOKEN=legacyApiClientAppToken
GLPI_USERNAME=glpi
GLPI_PASSWORD=glpi
